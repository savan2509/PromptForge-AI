# Postgres connection strings (Supabase: use the pooled connection for DATABASE_URL,
# and the direct connection for DIRECT_URL, used by Prisma migrations)
DATABASE_URL="postgresql://user:password@host:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Gemini API
GEMINI_API_KEY=""

# Public site URL — used for canonical links, sitemap.xml, robots.txt, and Open Graph tags.
# Set this to your real production domain when deploying.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
